generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String?
  role      String   @default("unassigned") // 'student', 'teacher', or 'unassigned'
  provider  String   @default("local") // 'local' or 'google'
  googleId  String?  @unique
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  notes          Note[]
  quizzes        Quiz[]
  quizAttempts   QuizAttempt[]
  flashcards     Flashcard[]
  chatMessages   ChatMessage[]
}

model StudentProfile {
  id                 String   @id @default(uuid())
  userId             String   @unique
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  institution        String?
  course             String?
  semester           String?
  learningPreference String?
  totalStudyHours    Int      @default(0)
  createdAt          DateTime @default(now())
}

model TeacherProfile {
  id             String   @id @default(uuid())
  userId         String   @unique
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  organization   String?
  department     String?
  specialization String?
  experience     Int?
  createdAt      DateTime @default(now())
}

model Note {
  id        String   @id @default(uuid())
  title     String
  filePath  String
  fileType  String
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  quizzes      Quiz[]
  flashcards   Flashcard[]
  chatMessages ChatMessage[]
}

model Quiz {
  id            String   @id @default(uuid())
  title         String
  difficulty    String   @default("medium") // easy, medium, hard
  questionsJson String   // Stores JSON array of QuizQuestion
  noteId        String?
  note          Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  studentId     String
  student       User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  attempts QuizAttempt[]
}

model QuizAttempt {
  id             String   @id @default(uuid())
  quizId         String
  quiz           Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId      String
  student        User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  score          Int
  totalQuestions Int
  accuracy       Int
  weakTopicsJson String   // Stores JSON array of weak topics
  createdAt      DateTime @default(now())
}

model Flashcard {
  id        String   @id @default(uuid())
  question  String
  answer    String
  topic     String
  type      String   @default("concept") // definition, concept, formula, comparison
  noteId    String?
  note      Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  studentId String
  student   User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
}

model ChatMessage {
  id          String   @id @default(uuid())
  studentId   String
  student     User     @relation(fields: [studentId], references: [id], onDelete: Cascade)
  noteId      String?
  note        Note?    @relation(fields: [noteId], references: [id], onDelete: SetNull)
  question    String
  answer      String
  sourcesJson String   // Stores JSON array of ChatSource
  createdAt   DateTime @default(now())
}
